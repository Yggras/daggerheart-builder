{
  "name": "daggerheart-builder",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "type": "module",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "validate:srd": "tsx scripts/validate-srd.ts",
    "validate:srd:candidates": "tsx scripts/validate-srd.ts data/srd/generated/entries.candidates.json",
    "validate:srd:candidates:adversaries": "tsx scripts/validate-srd.ts data/srd/generated/adversaries.candidates.json",
    "validate:srd:candidates:ancestries": "tsx scripts/validate-srd.ts data/srd/generated/ancestries.candidates.json",
    "validate:srd:candidates:armor": "tsx scripts/validate-srd.ts data/srd/generated/armor.candidates.json",
    "validate:srd:candidates:communities": "tsx scripts/validate-srd.ts data/srd/generated/communities.candidates.json",
    "validate:srd:candidates:classes-subclasses": "tsx scripts/validate-srd.ts data/srd/generated/classes-subclasses.candidates.json",
    "validate:srd:candidates:domain-cards": "tsx scripts/validate-srd.ts data/srd/generated/domain-cards.candidates.json",
    "validate:srd:candidates:loot": "tsx scripts/validate-srd.ts data/srd/generated/loot.candidates.json",
    "validate:srd:candidates:weapons": "tsx scripts/validate-srd.ts data/srd/generated/weapons.candidates.json",
    "validate:srd:candidates:environments": "tsx scripts/validate-srd.ts data/srd/generated/environments.candidates.json",
    "extract:srd:adversaries": "tsx scripts/extract-adversaries.ts",
    "extract:srd:environments": "tsx scripts/extract-environments.ts",
    "extract:srd:ancestries-communities": "tsx scripts/extract-ancestries-communities.ts",
    "extract:srd:classes-subclasses": "tsx scripts/extract-classes-subclasses.ts",
    "extract:srd:domain-cards": "tsx scripts/extract-domain-cards.ts",
    "extract:srd:rules": "tsx scripts/extract-rule-references.ts",
    "extract:srd:armor": "tsx scripts/extract-armor.ts",
    "extract:srd:loot": "tsx scripts/extract-loot.ts",
    "extract:srd:weapons": "tsx scripts/extract-weapons.ts"
  },
  "dependencies": {
    "@expo/metro-runtime": "^56.0.12",
    "expo": "^56.0.4",
    "expo-constants": "~56.0.15",
    "expo-linking": "~56.0.11",
    "expo-router": "^56.2.6",
    "expo-status-bar": "^56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "^0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "^4.25.2",
    "react-native-web": "^0.21.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.6",
    "typescript": "~6.0.3"
  }
}
